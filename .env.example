# ============ AI API 配置 ============
# 必需：AI API 密钥
AI_API_KEY=your-api-key-here

# 可选：AI Provider（默认：bailian）
# 支持：bailian, openai, deepseek
AI_PROVIDER=bailian

# 可选：AI 模型名称（默认根据 provider 自动选择）
# bailian: qwen-turbo, qwen-plus, qwen-max
# openai: gpt-4o-mini, gpt-4o
# deepseek: deepseek-chat, deepseek-coder
AI_MODEL=qwen-turbo

# 可选：自定义 API 地址（一般不需要修改）
# AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 安全配置 ============
# Cron Job 验证密钥（用于 Vercel Cron Jobs）
CRON_SECRET=your-random-secret-here
